# VirusTotal API Key
VIRUSTOTAL_API_KEY=YOUR VIRUS TOTAL API KEY

# Flask Configuration
SECRET_KEY=your_secret_key_here_12345
DEBUG=True

# File Upload Settings
MAX_CONTENT_LENGTH=104857600
ALLOWED_EXTENSIONS=exe,dll,doc,pdf,zip,rar,jar,apk,txt,com,bat,scr,ps1,py,js,vbs,docx,xlsx,ppt,pptx,7z,gz,tar,html,css,jpg,png,gif,iso,bin,msi

# Database
DATABASE_PATH=database/scans.db

# Report Settings
REPORT_PATH=reports/